APP_NAME="AgentHub API"
APP_ENV="development"
API_V1_PREFIX="/api/v1"
BACKEND_CORS_ORIGINS="http://localhost:3000"

# Use your MongoDB Atlas URI here, for example:
# mongodb+srv://<username>:<password>@<cluster-url>/agenthub?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-url>/agenthub?retryWrites=true&w=majority"
MONGODB_DB_NAME="agenthub"

JWT_SECRET_KEY="change-this-secret"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_SESSION_TOKEN_EXPIRE_DAYS=30
EMAIL_CODE_EXPIRE_MINUTES=10

SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USERNAME="your-smtp-username"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_EMAIL="no-reply@example.com"
SMTP_FROM_NAME="AgentHub"
SMTP_USE_TLS=true
SMTP_USE_SSL=false

OPENAI_API_KEY="your-openai-api-key"
OPENAI_AGENT_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_FOLDER="agenthub/knowledge"
